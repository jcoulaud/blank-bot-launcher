# === Required ===
SOLANA_PRIVATE_KEY=                   # base58, hot wallet only — never reuse with your main wallet
BLANK_API_KEY=                        # https://blank.build dashboard
BLANK_API_BASE_URL=https://api.blank.build
X_BEARER_TOKEN=                       # X Developer Bearer Token (App-Only) — the only X credential the bot actually uses
GOOGLE_GENERATIVE_AI_API_KEY=         # https://aistudio.google.com (free tier)
PINATA_JWT=                           # https://pinata.cloud (free tier)

# === Optional (with defaults) ===
LLM_MODEL=gemini-2.5-flash
IMAGE_MODEL=gemini-2.5-flash-image
CLASSIFIER_THRESHOLD=0.85
PER_AUTHOR_COOLDOWN_HOURS=6
MAX_SOL_PER_LAUNCH=0.05
MAX_LAUNCHES_PER_DAY=3
MAX_SOL_PER_DAY=0.15
WARN_IF_BALANCE_ABOVE_SOL=2
RPC_URL=https://api.mainnet-beta.solana.com
ACCOUNTS_FILE=./accounts.yaml
SHUTDOWN_TIMEOUT_S=90
DB_PATH=./data/bot.db
LOG_LEVEL=info
SKIP_OLDER_THAN_S=300                 # ignore tweets older than 5 minutes on startup

# === Optional (off by default — uncomment to enable) ===
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# DASHBOARD_PORT=3000
