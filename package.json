{
  "name": "blank-bot",
  "version": "0.1.0",
  "description": "Open-source reference bot that launches Solana memecoins from influencer tweets via the blank.build SDK",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "blank-bot": "./bin/blank-bot.mjs"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src test",
    "format": "biome format --write src test",
    "check": "tsc --noEmit && biome check src test",
    "check-config": "tsx src/index.ts --check-config"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.67",
    "@blankdotbuild/sdk": "^2.0.2",
    "@solana/web3.js": "^1.98.4",
    "ai": "^6.0.174",
    "async-mutex": "^0.5.0",
    "better-sqlite3": "^12.9.0",
    "bs58": "^6.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "telegraf": "^4.16.3",
    "twitter-api-v2": "^1.29.0",
    "yaml": "^2.8.4",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
